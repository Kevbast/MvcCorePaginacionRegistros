@model List<Empleado>

<h1 style="color:blueviolet"> Paginación en grupo EMPLEADOS</h1>
<hr />
@Html.Raw(ViewData["LINKS"])



@{
    int numPagina = 1;
    int numRegistros = (int)@ViewData["NUMREGISTRO"];

    //ViewData["LINKS"] = html;

}

<ul class="list-group list-group-horizontal">
    @for (int i = 1; i <= numRegistros; i += 3)
    {
        <li class="list-group-item">
            <a asp-controller="Paginacion" asp-action="GrupoEmpleados" asp-route-posicion="@i">
                @numPagina
            </a>
        </li>
        
        numPagina++; 
    }
</ul>


@if (Model != null)
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>EMP_NO</th>
                <th>APELLIDO</th>
                <th>OFICIO</th>
                <th>SALARIO</th>
                <th>DEPT_NO</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Empleado emp in Model)
            {
                <tr>
                    <td>@emp.IdEmpleado </td>
                    <td>@emp.Apellido </td>
                    <td> @emp.Oficio </td>
                    <td> @emp.Salario </td>
                    <td>@emp.IdDepartamento</td>
                </tr>
            }

        </tbody>
    </table>
}
else
{
    <h2>NO SE CARGAN LOS empleados</h2>
}